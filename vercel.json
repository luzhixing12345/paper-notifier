{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/**/*.py": {
      "maxDuration": 60,
      "includeFiles": "{assets/**,paper_cache/**}"
    }
  },
  "rewrites": [
    {
      "source": "/api/papers",
      "destination": "/api/index?path=/api/papers"
    },
    {
      "source": "/assets/:path*",
      "destination": "/api/index?path=/assets/:path*"
    },
    {
      "source": "/favicon.ico",
      "destination": "/api/index?path=/assets/favicon.svg"
    },
    {
      "source": "/",
      "destination": "/api/index?path=/"
    }
  ]
}
